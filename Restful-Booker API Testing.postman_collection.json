    {
      "name": "Booking",
      "item": [
        {
          "name": "BOOK-01_GetBookingIds-NoParams",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус ответа 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Ответ является массивом и содержит элементы\", function () {",
                  "    let responseData = pm.response.json();",
                  "    pm.expect(responseData).to.be.an(\"array\");",
                  "    pm.expect(responseData.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"Первый элемент массива содержит числовое поле bookingid\", function () {",
                  "    let responseData = pm.response.json();",
                  "    pm.expect(responseData[0]).to.have.property(\"bookingid\");",
                  "    pm.expect(responseData[0].bookingid).to.be.a(\"number\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
        },
